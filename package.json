{
  "name": "e2e-ts-go",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*"
    ]
  },
  "type": "module",
  "scripts": {
    "dev": "moon run :dev",
    "check": "moon run :check",
    "clean": "moon run :clean",
    "clean-root": "rm -rf node_modules",
    "build": "moon run :build",
    "start": "moon run :start",
    "swagger": "moon run :swagger",
    "openapi": "openapi-ts",
    "sync": "bun update --interactive --recursive --latest",
    "migrate-status": "moon run server:migrate-status",
    "migrate-up": "moon run server:migrate-up",
    "migrate-down": "moon run server:migrate-down",
    "migrate-reset": "moon run server:migrate-reset",
    "db-seed": "moon run server:seed",
    "docker-dev": "docker compose -f docker-compose.dev.yml up -d",
    "docker-dev:reset": "docker compose -f docker-compose.dev.yml down -v && docker compose -f docker-compose.dev.yml up -d",
    "docker-build": "DOCKER_BUILDKIT=1 docker compose --progress=plain build && docker compose up -d",
    "db-tables": "docker exec e2e-ts-go-postgres psql -U postgres -d e2e-ts-go -c '\\dt'",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@hey-api/openapi-ts": "^0.97.1",
    "@moonrepo/cli": "^2.2.4",
    "@tanstack/eslint-plugin-query": "^5.97.0",
    "@types/bun": "^1.3.14",
    "@typescript/native-preview": "^7.0.0-dev.20260515.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-you-might-not-need-an-effect": "^0.10.1",
    "eslint-plugin-use-no-memo": "^1.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "oxlint-tsgolint": "^0.22.1",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint --type-aware --type-check",
      "oxfmt --write ."
    ],
    "*.{json,md}": [
      "oxfmt --write ."
    ],
    "*.go": [
      "gofumpt -w -l"
    ]
  },
  "engines": {
    "bun": ">=1.3.10",
    "npm": "this-project-uses-bun",
    "pnpm": "this-project-uses-bun",
    "yarn": "this-project-uses-bun"
  },
  "packageManager": "bun@1.3.5"
}
