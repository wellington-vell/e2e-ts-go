{
  "name": "e2e-ts-go",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*"
    ]
  },
  "type": "module",
  "scripts": {
    "dev": "moon run :dev",
    "check": "moon run :check",
    "clean": "moon run :clean",
    "clean-root": "rm -rf node_modules",
    "build": "moon run :build",
    "start": "moon run :start",
    "swagger": "moon run :swagger",
    "openapi": "openapi-ts",
    "migrate-create": "sh -c 'MIGRATION_NAME=\"$1\" MIGRATION_TYPE=\"$2\" moon run server:migrate-create' --",
    "migrate-up": "moon run server:migrate-up",
    "migrate-down": "moon run server:migrate-down",
    "migrate-up-to": "sh -c 'MIGRATION_VERSION=\"$1\" moon run server:migrate-up-to' --",
    "migrate-down-to": "sh -c 'MIGRATION_VERSION=\"$1\" moon run server:migrate-down-to' --",
    "docker-dev": "docker compose -f docker-compose.dev.yml up -d",
    "docker-dev:reset": "docker compose -f docker-compose.dev.yml down -v && docker compose -f docker-compose.dev.yml up -d",
    "docker-build": "DOCKER_BUILDKIT=1 docker compose --progress=plain build && docker compose up -d",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@hey-api/openapi-ts": "^0.95.0",
    "@moonrepo/cli": "^2.1.4",
    "@tanstack/eslint-plugin-query": "^5.97.0",
    "@types/bun": "^1.3.12",
    "@typescript/native-preview": "^7.0.0-dev.20260411.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-you-might-not-need-an-effect": "^0.9.3",
    "eslint-plugin-use-no-memo": "^1.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint --type-aware --type-check",
      "oxfmt --write ."
    ],
    "*.{json,md}": [
      "oxfmt --write ."
    ],
    "*.go": [
      "gofumpt -w -l"
    ]
  },
  "engines": {
    "bun": ">=1.3.10",
    "npm": "this-project-uses-bun",
    "pnpm": "this-project-uses-bun",
    "yarn": "this-project-uses-bun"
  },
  "packageManager": "bun@1.3.5"
}
