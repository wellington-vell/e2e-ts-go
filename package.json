{
  "name": "e2e-ts-go",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*"
    ]
  },
  "type": "module",
  "scripts": {
    "dev": "moon run :dev",
    "check": "moon run :check",
    "clean": "moon run :clean",
    "build": "moon run :build",
    "start": "moon run :start",
    "openapi": "~/go/bin/swag init -g apps/server/cmd/main.go -o apps/server/docs 2>&1 || $HOME/go/bin/swag init -g apps/server/cmd/main.go -o apps/server/docs 2>&1 || which swag"
  },
  "devDependencies": {
    "@moonrepo/cli": "^1.41.7",
    "@types/bun": "^1.3.6",
    "oxfmt": "^0.25.0",
    "oxlint": "^1.40.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.5"
}
